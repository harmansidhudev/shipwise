      "url": "https://[CUSTOMIZE_DOMAIN]/pricing",
      "availability": "https://schema.org/InStock",
      "billingIncrement": "P1M",
      "priceValidUntil": "[CUSTOMIZE] 2026-12-31"
    },
    {
      "@type": "Offer",
      "name": "[CUSTOMIZE] Enterprise",
